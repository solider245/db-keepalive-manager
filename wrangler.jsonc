{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "db-keepalive",
  "main": "src/index.js",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "DATABASE_KV",
      "id": "KV_ID_PLACEHOLDER",
      "preview_id": "KV_ID_PLACEHOLDER"
    }
  ],
  "vars": {
    "ADMIN_KEY": ""
  }
}
